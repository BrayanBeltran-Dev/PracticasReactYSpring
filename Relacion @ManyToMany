@Service
public class VideojuegoService {

    @Autowired
    private VideojuegoRepository videojuegoRepository;

    @Autowired
    private CategoriaRepository categoriaRepository;

    private CategoriaDTO mapCategoriaToDTO(Categoria categoria) {
        return new CategoriaDTO(categoria.getId(), categoria.getNombre());
    }

    private VideojuegoDTO mapToDTO(Videojuego videojuego) {
        VideojuegoDTO dto = new VideojuegoDTO();
        dto.setId(videojuego.getId());
        dto.setTitulo(videojuego.getTitulo());
        List<CategoriaDTO> categoriasDTO = videojuego.getCategorias() != null
                ? videojuego.getCategorias().stream()
                    .map(this::mapCategoriaToDTO)
                    .collect(Collectors.toList())
                : new ArrayList<>();
        dto.setCategorias(categoriasDTO);
        return dto;
    }

    // LISTAR
    public List<VideojuegoDTO> findAll() {
        return videojuegoRepository.findAll()
                .stream()
                .map(this::mapToDTO)
                .collect(Collectors.toList());
    }

    // CREAR
    public VideojuegoDTO save(VideojuegoRequestDTO requestDTO) {
        Videojuego videojuego = new Videojuego();
        videojuego.setTitulo(requestDTO.getTitulo());
        if (requestDTO.getCategoriaIds() != null && !requestDTO.getCategoriaIds().isEmpty()) {
            List<Categoria> categorias = categoriaRepository.findAllById(requestDTO.getCategoriaIds());
            videojuego.setCategorias(categorias);
        }
        return mapToDTO(videojuegoRepository.save(videojuego));
    }

    // ACTUALIZAR
    public Optional<VideojuegoDTO> update(Long id, VideojuegoRequestDTO requestDTO) {
        return videojuegoRepository.findById(id).map(existente -> {
            existente.setTitulo(requestDTO.getTitulo());
            if (requestDTO.getCategoriaIds() != null) {
                List<Categoria> categorias = categoriaRepository.findAllById(requestDTO.getCategoriaIds());
                existente.setCategorias(categorias);
            }
            return mapToDTO(videojuegoRepository.save(existente));
        });
    }

    // ELIMINAR
    public boolean deleteById(Long id) {
        if (videojuegoRepository.existsById(id)) {
            videojuegoRepository.deleteById(id);
            return true;
        }
        return false;
    }
}


