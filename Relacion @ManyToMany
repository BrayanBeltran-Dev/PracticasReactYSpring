import { useState, useEffect } from "react";

const API_URL = "http://localhost:8080/api/videojuegos";

export default function Form() {
  const [videojuegos, setVideojuegos] = useState([]);
  const [titulo, setTitulo] = useState("");
  const [editando, setEditando] = useState(null);

  useEffect(() => { cargar(); }, []);

  const cargar = () =>
    fetch(API_URL).then((r) => r.json()).then(setVideojuegos);

  const handleSubmit = async (e) => {
    e.preventDefault();
    const opts = {
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ titulo, categoriaIds: [] }),
    };
    if (editando) {
      await fetch(`${API_URL}/${editando.id}`, { method: "PUT", ...opts });
    } else {
      await fetch(API_URL, { method: "POST", ...opts });
    }
    setTitulo("");
    setEditando(null);
    cargar();
  };

  const handleEditar = (vj) => { setEditando(vj); setTitulo(vj.titulo); };

  const handleEliminar = async (id) => {
    if (!confirm("¿Eliminar?")) return;
    await fetch(`${API_URL}/${id}`, { method: "DELETE" });
    cargar();
  };

  return (
    <div className="container mt-4">
      <form onSubmit={handleSubmit} className="mb-4">
        <div className="input-group">
          <input
            type="text"
            className="form-control"
            placeholder="Título del videojuego"
            value={titulo}
            onChange={(e) => setTitulo(e.target.value)}
            required
          />
          <button className="btn btn-dark" type="submit">
            {editando ? "Actualizar" : "Guardar"}
          </button>
          {editando && (
            <button
              type="button"
              className="btn btn-outline-secondary"
              onClick={() => { setEditando(null); setTitulo(""); }}
            >
              Cancelar
            </button>
          )}
        </div>
      </form>

      <table className="table table-bordered table-hover">
        <thead className="table-dark">
          <tr>
            <th>#</th>
            <th>Título</th>
            <th>Categorías</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {videojuegos.length === 0 ? (
            <tr>
              <td colSpan={4} className="text-center text-muted">Sin registros</td>
            </tr>
          ) : (
            videojuegos.map((vj) => (
              <tr key={vj.id}>
                <td>{vj.id}</td>
                <td>{vj.titulo}</td>
                <td>
                  {vj.categorias?.map((c) => (
                    <span key={c.id} className="badge bg-secondary me-1">{c.nombre}</span>
                  ))}
                </td>
                <td>
                  <button className="btn btn-sm btn-outline-dark me-2" onClick={() => handleEditar(vj)}>Editar</button>
                  <button className="btn btn-sm btn-outline-danger" onClick={() => handleEliminar(vj.id)}>Eliminar</button>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  );
}





